    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700&family=Quicksand:wght@300;400;500;600&display=swap');
        
        :root {
            --neon-pink: #ff00ff;
            --neon-blue: #00f2ff;
            --neon-green: #39ff14;
            --neon-purple: #bc13fe;
            --dark-bg: #0f0f12;
        }
        
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: var(--dark-bg);
            color: white;
            overflow-x: hidden;
        }
        
        .neon-text {
            font-family: 'Orbitron', sans-serif;
            text-shadow: 0 0 5px #fff, 0 0 10px #fff, 0 0 15px var(--neon-pink), 0 0 20px var(--neon-pink), 0 0 25px var(--neon-pink);
        }
        
        .neon-blue {
            text-shadow: 0 0 5px #fff, 0 0 10px #fff, 0 0 15px var(--neon-blue), 0 0 20px var(--neon-blue), 0 0 25px var(--neon-blue);
        }
        
        .neon-green {
            text-shadow: 0 0 5px #fff, 0 0 10px #fff, 0 0 15px var(--neon-green), 0 0 20px var(--neon-green), 0 0 25px var(--neon-green);
        }
        
        .neon-purple {
            text-shadow: 0 0 5px #fff, 0 0 10px #fff, 0 0 15px var(--neon-purple), 0 0 20px var(--neon-purple), 0 0 25px var(--neon-purple);
        }
        
        .neon-border {
            border: 2px solid var(--neon-pink);
            box-shadow: 0 0 5px var(--neon-pink), 0 0 10px var(--neon-pink), inset 0 0 5px var(--neon-pink);
        }
        
        .neon-border-blue {
            border: 2px solid var(--neon-blue);
            box-shadow: 0 0 5px var(--neon-blue), 0 0 10px var(--neon-blue), inset 0 0 5px var(--neon-blue);
        }
        
        .neon-border-green {
            border: 2px solid var(--neon-green);
            box-shadow: 0 0 5px var(--neon-green), 0 0 10px var(--neon-green), inset 0 0 5px var(--neon-green);
        }
        
        .neon-border-purple {
            border: 2px solid var(--neon-purple);
            box-shadow: 0 0 5px var(--neon-purple), 0 0 10px var(--neon-purple), inset 0 0 5px var(--neon-purple);
        }
        
        .neon-btn {
            position: relative;
            display: inline-block;
            padding: 10px 20px;
            color: var(--neon-pink);
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
            overflow: hidden;
            transition: 0.5s;
            border: 2px solid var(--neon-pink);
            box-shadow: 0 0 5px var(--neon-pink), 0 0 10px var(--neon-pink);
        }
        
        .neon-btn:hover {
            background-color: var(--neon-pink);
            color: var(--dark-bg);
            box-shadow: 0 0 10px var(--neon-pink), 0 0 20px var(--neon-pink), 0 0 40px var(--neon-pink);
        }
        
        .neon-btn-blue {
            color: var(--neon-blue);
            border: 2px solid var(--neon-blue);
            box-shadow: 0 0 5px var(--neon-blue), 0 0 10px var(--neon-blue);
        }
        
        .neon-btn-blue:hover {
            background-color: var(--neon-blue);
            color: var(--dark-bg);
            box-shadow: 0 0 10px var(--neon-blue), 0 0 20px var(--neon-blue), 0 0 40px var(--neon-blue);
        }
        
        .neon-btn-green {
            color: var(--neon-green);
            border: 2px solid var(--neon-green);
            box-shadow: 0 0 5px var(--neon-green), 0 0 10px var(--neon-green);
        }
        
        .neon-btn-green:hover {
            background-color: var(--neon-green);
            color: var(--dark-bg);
            box-shadow: 0 0 10px var(--neon-green), 0 0 20px var(--neon-green), 0 0 40px var(--neon-green);
        }
        
        .grid-item {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .grid-item:hover {
            transform: translateY(-5px);
        }
        
        .nav-link {
            position: relative;
            transition: all 0.3s ease;
        }
        
        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: var(--neon-pink);
            box-shadow: 0 0 5px var(--neon-pink), 0 0 10px var(--neon-pink);
            transition: width 0.3s ease;
        }
        
        .nav-link:hover::after {
            width: 100%;
        }
        
        .glow-effect {
            animation: glow 2s infinite alternate;
        }
        
        @keyframes glow {
            from {
                box-shadow: 0 0 5px var(--neon-pink), 0 0 10px var(--neon-pink);
            }
            to {
                box-shadow: 0 0 10px var(--neon-pink), 0 0 20px var(--neon-pink), 0 0 30px var(--neon-pink);
            }
        }
        
        .grid-bg {
            background-image: linear-gradient(rgba(15, 15, 18, 0.9), rgba(15, 15, 18, 0.9)), 
                              repeating-linear-gradient(0deg, transparent, transparent 50px, rgba(255, 0, 255, 0.1) 50px, rgba(255, 0, 255, 0.1) 51px),
                              repeating-linear-gradient(90deg, transparent, transparent 50px, rgba(0, 242, 255, 0.1) 50px, rgba(0, 242, 255, 0.1) 51px);
        }
        
        .mobile-menu {
            display: none;
        }
        
        @media (max-width: 768px) {
            .desktop-menu {
                display: none;
            }
            .mobile-menu {
                display: block;
            }
        }
    </style>
</head>
